rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // System configuration (e.g. intro page settings)
    match /system/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated() && getUserData().get('role', 'user') == 'admin' || getUserData().get('permissions', {}).get('all', false) == true;
    }

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasSchool(school) {
      return getUserData().get('role', 'user') == 'admin' || 
             getUserData().get('permissions', {}).get('all', false) == true || 
             school in getUserData().get('schools', []) || 
             'all' in getUserData().get('schools', []);
    }

    function isManager() {
       let perms = getUserData().get('permissions', {});
       return perms.get('userManagement', false) == true || (perms.get('userManagement', [])).size() > 0;
    }

    function isSecretariatKey(key) {
       return key == 'secretariatStudents' || key == 'secretariatStaff' || key == 'users' || key == 'profile' || key == 'availableSchools' || key == 'availableYears' || key == 'schoolBranches' || key == 'selfEvaluationTemplates' || key == 'courseEvaluationSchema_v2' || key == 'metricsList' || key == 'adminMetricsList' || key == 'branchMetrics' || key == 'adminBranchMetrics' || key == 'adminFollowUpTypes' || key == 'adminActivitiesList' || key == 'adminBranchActivities' || key == 'adminIndividualReportFields' || key == 'adminIndividualReports' || key == 'addedTasks' || key == 'postponedTasks' || key == 'issueRecommendations' || key == 'creativityRecords' || key == 'trainingEvaluations';
    }

    // User mapping document
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == uid);
    }

    // School data
    match /schools/{school} {
      
      // Shared data (profile, templates, etc.)
      match /shared/{key} {
        // Allow anonymous reads for login-essential keys
        allow read: if isAuthenticated() && (
          key == 'users' || 
          key == 'profile' || 
          key == 'availableSchools' || 
          key == 'availableYears' || 
          key == 'schoolBranches' || 
          key == 'selfEvaluationTemplates' ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && hasSchool(school))
        );
        
        allow write: if isAuthenticated() && 
                     exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
                       getUserData().get('role', 'user') == 'admin' || 
                       getUserData().get('permissions', {}).get('all', false) == true || 
                       (key == 'users' && isManager()) ||
                       (hasSchool(school) && isSecretariatKey(key))
                     );
      }

      // User-specific data
      match /users/{userId}/data/{key} {
        allow read, write: if isAuthenticated() && 
                             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                             hasSchool(school);
      }
    }

    // Issues and Solutions Log
    match /issuesAndSolutions_log/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Case Studies Log
    match /CaseStudies/{docId} {
      allow read, write: if isAuthenticated();
    }

    // GradeSheets
    match /GradeSheets/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
