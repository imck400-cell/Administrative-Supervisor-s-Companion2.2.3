rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid} (Firebase Auth UID)
    // Fields:
    //   - customUserId: string (required)
    //   - role: string (required, 'admin' or 'user')
    //   - schools: list (required)
    //
    // Collection: schools/{school}/shared/{key}
    // Document ID: {key} (e.g., 'profile', 'taskTemplates')
    // Fields:
    //   - data: any (required)
    //
    // Collection: schools/{school}/users/{userId}/data/{key}
    // Document ID: {key} (e.g., 'dailyReports', 'substitutions')
    // Fields:
    //   - items: list (required)
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasSchool(school) {
      return school in getUserData().schools || 'all' in getUserData().schools;
    }

    // User mapping document
    match /users/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && request.auth.uid == uid;
    }

    // School data
    match /schools/{school} {
      
      // Shared data (profile, templates, etc.)
      match /shared/{key} {
        allow read: if isAuthenticated() && (key == 'users' || key == 'profile' || key == 'availableSchools' || key == 'availableYears' || (userExists() && hasSchool(school)));
        allow write: if isAuthenticated() && userExists() && hasSchool(school) && getUserData().role == 'admin';
      }

      // User-specific data
      match /users/{userId}/data/{key} {
        allow read: if isAuthenticated() && userExists() && hasSchool(school);
        allow write: if isAuthenticated() && userExists() && hasSchool(school) && 
          (getUserData().role == 'admin' || getUserData().customUserId == userId);
      }
    }

    // Issues and Solutions Log (New Collection)
    match /issuesAndSolutions_log/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}

